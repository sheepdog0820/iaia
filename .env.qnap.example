# Copy this file to .env.qnap on the QNAP NAS and change passwords before starting.
APP_ENV=local
ENVIRONMENT=development
ENV_FILE=.env.qnap
SECRET_KEY=change-this-qnap-development-secret-key
DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,NAS-CTHULHU,192.168.0.139
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://NAS-CTHULHU:8000,http://192.168.0.139:8000
PUBLIC_SITE_URL=http://NAS-CTHULHU:8000
SITE_ID=1

DB_ENGINE=postgres
DB_NAME=iaia
DB_USER=iaia
DB_PASSWORD=change-this-postgres-password
DB_HOST=db
DB_PORT=5432
POSTGRES_DB=iaia
POSTGRES_USER=iaia
POSTGRES_PASSWORD=change-this-postgres-password

USE_REDIS_CACHE=False
USE_S3_STORAGE=False
STRIPE_CHECKOUT_ENABLED=False
CONTACT_EMAIL=support@example.com
DEFAULT_FROM_EMAIL=noreply@example.com
ACCOUNT_EMAIL_VERIFICATION=none

WEB_PORT=8000
RUN_MIGRATIONS=True
RUN_COLLECTSTATIC=True
COLLECTSTATIC_ALLOW_FAILURE=True

CREATE_DEV_LOGIN_USER=True
DEV_LOGIN_USERNAME=testuser
DEV_LOGIN_PASSWORD=change-this-test-password
DEV_LOGIN_EMAIL=testuser@example.local
DEV_LOGIN_NICKNAME=Test User
DEV_LOGIN_STAFF=False
DEV_LOGIN_PREMIUM=False

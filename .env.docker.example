# Django environment file for Docker Compose sample runs.
# Copy this file only for local Docker testing. Put real secrets in ignored local env files.
APP_ENV=local
ENVIRONMENT=development
SECRET_KEY=docker-compose-example-secret-key-without-dollar-sign
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

DB_ENGINE=postgres
DB_NAME=iaia
DB_USER=iaia
DB_PASSWORD=iaia
DB_HOST=db
DB_PORT=5432

USE_REDIS_CACHE=False
USE_S3_STORAGE=False
STRIPE_CHECKOUT_ENABLED=False
PUBLIC_SITE_URL=http://127.0.0.1:8000
CONTACT_EMAIL=support@example.com
DEFAULT_FROM_EMAIL=noreply@example.com
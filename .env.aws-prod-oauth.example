# AWS production OAuth/API settings for tableno.jp.
# Use this as a non-secret reference for AWS Secrets Manager / ECS task env vars.
# Do not commit real Client IDs or Client Secrets.

APP_ENV=aws-prod
ENVIRONMENT=production
DEBUG=False
ALLOWED_HOSTS=tableno.jp,www.tableno.jp
CSRF_TRUSTED_ORIGINS=https://tableno.jp,https://www.tableno.jp
SITE_ID=1
SITE_URL=https://tableno.jp

# Minimal required production runtime placeholders for local config validation.
# In ECS, these should come from task environment variables and Secrets Manager.
SECRET_KEY=replace-with-64-plus-random-chars-from-secrets-manager-TablenoProdSecretKey2026
DB_ENGINE=mysql
DB_NAME=tableno_prod
DB_USER=tableno_user
DB_PASSWORD=replace-with-secret-manager-value
DB_HOST=replace-with-rds-endpoint
DB_PORT=3306
REDIS_URL=rediss://replace-with-elasticache-endpoint:6379/0
REDIS_SSL_CERT_REQS=none

# Google OAuth
# Register this redirect URI in Google Cloud Console:
# - https://tableno.jp/accounts/google/login/callback/
GOOGLE_OAUTH_CLIENT_ID=replace-with-production-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-secret-manager-value

# X / Twitter OAuth2
# Register this callback URL in the X Developer Portal:
# - https://tableno.jp/accounts/twitter_oauth2/login/callback/
TWITTER_CLIENT_ID=replace-with-production-twitter-client-id
TWITTER_CLIENT_SECRET=replace-with-secret-manager-value
TWITTER_REDIRECT_URI=https://tableno.jp/accounts/twitter_oauth2/login/callback/

# Discord OAuth2
# Register this redirect URL in the Discord Developer Portal:
# - https://tableno.jp/accounts/discord/login/callback/
DISCORD_CLIENT_ID=replace-with-production-discord-client-id
DISCORD_CLIENT_SECRET=replace-with-secret-manager-value
DISCORD_REDIRECT_URI=https://tableno.jp/accounts/discord/login/callback/

# Optional public origins and outbound email identity.
CORS_ALLOWED_ORIGINS=https://tableno.jp,https://www.tableno.jp
DEFAULT_FROM_EMAIL=noreply@tableno.jp
SERVER_EMAIL=noreply@tableno.jp
ADMIN_EMAIL=support@tableno.jp
CONTACT_EMAIL=support@tableno.jp
SUPPORT_EMAIL=support@tableno.jp

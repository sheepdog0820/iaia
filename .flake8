[flake8]
# CI gate for breakage-level Python errors. Black and isort enforce formatting separately.
select = E9,F63,F7,F82
max-line-length = 120
extend-ignore = E203,W503
jobs = 1
exclude =
    .git,
    .pytest_cache,
    .codex,
    .claude,
    venv,
    venv_local311,
    node_modules,
    staticfiles,
    media,
    codex-build-output,
    playwright-report,
    test-results,
    tmp,
    skills
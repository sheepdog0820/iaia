# Django設定
APP_ENV=local
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ソーシャル認証 - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# ソーシャル認証 - Discord
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://127.0.0.1:8000/accounts/discord/login/callback/


# API認証設定
FRONTEND_URL=http://localhost:3000

# ソーシャル認証 - Twitter/X (OAuth2)
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_REDIRECT_URI=http://127.0.0.1:8000/accounts/twitter_oauth2/login/callback/

# データベース設定（本番環境用）
# PostgreSQL (旧設定)
DATABASE_URL=postgresql://user:password@localhost:5432/tableno

# MySQL (本番環境推奨)
DB_ENGINE=mysql
DB_NAME=tableno_prod
DB_USER=tableno_user
DB_PASSWORD=your-mysql-password
DB_HOST=localhost
DB_PORT=3306

# Email設定（本番環境用）
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@tableno.jp
SERVER_EMAIL=noreply@tableno.jp
ADMIN_EMAIL=support@tableno.jp
CONTACT_EMAIL=support@tableno.jp
SUPPORT_EMAIL=support@tableno.jp

# Stripe billing
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PREMIUM_PRICE_ID=price_your-monthly-premium-price-id
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_your-yearly-premium-price-id
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_CUSTOMER_PORTAL_CONFIGURATION_ID=bpc_your-customer-portal-configuration-id
STRIPE_REVOKE_ON_REFUND_OR_DISPUTE=True
PREMIUM_PRICE_LABEL=月額480円 / 年額4,800円
PREMIUM_MONTHLY_PRICE_LABEL=月額プラン
PREMIUM_MONTHLY_PRICE_DESCRIPTION=480円/月
PREMIUM_YEARLY_PRICE_LABEL=年額プラン
PREMIUM_YEARLY_PRICE_DESCRIPTION=4,800円/年
LEGAL_PAYMENT_METHOD=Stripe Checkoutで利用可能なクレジットカード等の決済手段。
LEGAL_PAYMENT_TIMING=初回申し込み時に課金され、以後は月額サブスクリプションとして自動更新されます。
LEGAL_SERVICE_DELIVERY_TIMING=決済完了後、Stripe Webhookの処理完了をもってプレミアム機能を利用できます。
LEGAL_CANCELLATION_METHOD=ログイン後のプレミアム管理画面からStripe Customer Portalへ移動し、いつでも解約できます。
LEGAL_CANCELLATION_EFFECT=解約後も支払い済み期間の終了まではプレミアム機能を利用できます。
LEGAL_REFUND_POLICY=デジタルサービスの性質上、決済完了後のお客様都合による返金は原則として受け付けません。重複請求や誤請求が確認された場合は個別に対応します。
LEGAL_SELLER_NAME=タブレノ運営
LEGAL_SELLER_ADDRESS=請求があった場合、遅滞なく開示します。
LEGAL_SELLER_PHONE=請求があった場合、遅滞なく開示します。
PUBLIC_SITE_URL=https://example.com

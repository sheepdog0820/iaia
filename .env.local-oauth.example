# Local OAuth/API verification settings.
# Copy values into .env or run with ENV_FILE=.env.local-oauth.example.
# Do not put real secrets in this example file.

APP_ENV=local
SECRET_KEY=local-oauth-verification-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SITE_URL=http://127.0.0.1:8000
DEFAULT_FROM_EMAIL=noreply@tableno.jp
SERVER_EMAIL=noreply@tableno.jp
ADMIN_EMAIL=support@tableno.jp
CONTACT_EMAIL=support@tableno.jp
SUPPORT_EMAIL=support@tableno.jp

# Google OAuth
# Register these redirect URIs in Google Cloud Console for local verification:
# - http://127.0.0.1:8000/accounts/google/login/callback/
# - http://localhost:8000/accounts/google/login/callback/
GOOGLE_CLIENT_ID=replace-with-local-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-local-google-client-secret
GOOGLE_OAUTH_CLIENT_ID=replace-with-local-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-local-google-client-secret

# X / Twitter OAuth2
# Register these callback URLs in the X Developer Portal:
# - http://127.0.0.1:8000/accounts/twitter_oauth2/login/callback/
# - http://localhost:8000/accounts/twitter_oauth2/login/callback/
TWITTER_CLIENT_ID=replace-with-local-twitter-client-id
TWITTER_CLIENT_SECRET=replace-with-local-twitter-client-secret
TWITTER_REDIRECT_URI=http://127.0.0.1:8000/accounts/twitter_oauth2/login/callback/

# Discord OAuth2
# Register these redirect URLs in the Discord Developer Portal:
# - http://127.0.0.1:8000/accounts/discord/login/callback/
# - http://localhost:8000/accounts/discord/login/callback/
DISCORD_CLIENT_ID=replace-with-local-discord-client-id
DISCORD_CLIENT_SECRET=replace-with-local-discord-client-secret
DISCORD_REDIRECT_URI=http://127.0.0.1:8000/accounts/discord/login/callback/

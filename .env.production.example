# 本番環境用の環境変数設定テンプレート
# このファイルを .env.production にコピーして利用してください。

# -----------------------------------------------------------------------------
# AWS Secrets Manager / SSM
# -----------------------------------------------------------------------------
# 推奨: ECS Task Definition の `secrets` で必要キーを直接注入する。
# 代替: 1つのJSON Secretを使う場合は以下のどちらかを設定する。
# AWS_SECRETS_JSON={"SECRET_KEY":"...","DB_PASSWORD":"...","REDIS_URL":"..."}
# AWS_SECRETS_FILE=/run/secrets/tableno.json

# -----------------------------------------------------------------------------
# Django 基本設定（必須）
# -----------------------------------------------------------------------------
APP_ENV=aws-prod
ENVIRONMENT=production
SECRET_KEY=your-production-secret-key
DEBUG=False
ALLOWED_HOSTS=tableno.jp,www.tableno.jp
CSRF_TRUSTED_ORIGINS=https://tableno.jp,https://www.tableno.jp
SITE_ID=1

# -----------------------------------------------------------------------------
# DB 設定（必須）
# -----------------------------------------------------------------------------
DB_ENGINE=mysql
DB_NAME=tableno_prod
DB_USER=tableno_user
DB_PASSWORD=your-database-password
# docker-compose.mysql.yml で db サービスを使う場合に必要
DB_ROOT_PASSWORD=your-root-password
DB_HOST=db
DB_PORT=3306
# AWS RDS でSSL接続する場合
# DB_SSL_MODE=required
# DB_SSL_CA=/app/certs/rds-ca.pem

# -----------------------------------------------------------------------------
# Redis 設定（必須）
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/1
# ElastiCache TLS の場合は rediss:// を利用
# REDIS_URL=rediss://your-cache-endpoint:6379/1
# REDIS_SSL_CERT_REQS=required

# -----------------------------------------------------------------------------
# S3 / CloudFront 設定（ISSUE-052）
# -----------------------------------------------------------------------------
USE_S3_STORAGE=False
# USE_S3_STORAGE=True の場合は以下を設定
# AWS_STORAGE_BUCKET_NAME=tableno-prod-assets
# AWS_S3_REGION_NAME=ap-northeast-1
# AWS_S3_CUSTOM_DOMAIN=dxxxxxxxxxxxx.cloudfront.net
# AWS_STATIC_LOCATION=static
# AWS_MEDIA_LOCATION=media
# AWS_QUERYSTRING_AUTH=False
# AWS_S3_SIGNATURE_VERSION=s3v4
# AWS_S3_ADDRESSING_STYLE=auto
# AWS_S3_CACHE_CONTROL=max-age=86400, public

# -----------------------------------------------------------------------------
# ログ設定
# -----------------------------------------------------------------------------
LOG_TO_STDOUT=True
ENABLE_FILE_LOGGING=False
LOG_DIR=/var/log/tableno

# -----------------------------------------------------------------------------
# メール設定
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@tableno.jp
SERVER_EMAIL=noreply@tableno.jp
ADMIN_EMAIL=support@tableno.jp
CONTACT_EMAIL=support@tableno.jp
SUPPORT_EMAIL=support@tableno.jp

# -----------------------------------------------------------------------------
# Billing / legal disclosure
# Keep Checkout disabled until ISSUE-077 external Stripe verification is complete.
# -----------------------------------------------------------------------------
STRIPE_CHECKOUT_ENABLED=False
STRIPE_SECRET_KEY=sk_test_or_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PREMIUM_PRICE_ID=price_monthly_replace_me
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_yearly_replace_me
STRIPE_PREMIUM_EXPECTED_CURRENCY=jpy
STRIPE_PREMIUM_MONTHLY_EXPECTED_UNIT_AMOUNT=480
STRIPE_PREMIUM_YEARLY_EXPECTED_UNIT_AMOUNT=4800
STRIPE_PUBLISHABLE_KEY=pk_test_or_live_replace_me
STRIPE_CUSTOMER_PORTAL_CONFIGURATION_ID=bpc_replace_me
STRIPE_REVOKE_ON_REFUND_OR_DISPUTE=True
PUBLIC_SITE_URL=https://tableno.jp
PREMIUM_PRICE_LABEL=Monthly 480 JPY / Yearly 4,800 JPY
PREMIUM_MONTHLY_PRICE_LABEL=Monthly plan
PREMIUM_MONTHLY_PRICE_DESCRIPTION=480 JPY/month
PREMIUM_YEARLY_PRICE_LABEL=Yearly plan
PREMIUM_YEARLY_PRICE_DESCRIPTION=4,800 JPY/year
LEGAL_PAYMENT_METHOD=Credit card and other payment methods available through Stripe Checkout.
LEGAL_PAYMENT_TIMING=Charged when the subscription starts and renewed on each billing cycle.
LEGAL_SERVICE_DELIVERY_TIMING=Premium access starts after payment completion and webhook processing.
LEGAL_CANCELLATION_METHOD=Users can cancel from the premium management page via Stripe Customer Portal.
LEGAL_CANCELLATION_EFFECT=Premium access remains available until the end of the paid billing period after cancellation.
LEGAL_REFUND_POLICY=Refunds are reviewed individually by support according to service policy.
LEGAL_SELLER_NAME=Tableno operations
LEGAL_SELLER_ADDRESS=Disclosed without delay upon request.
LEGAL_SELLER_PHONE=Disclosed without delay upon request.
# -----------------------------------------------------------------------------
# OAuth 設定
# -----------------------------------------------------------------------------
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://tableno.jp/accounts/discord/login/callback/

GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

TWITTER_CLIENT_ID=your-twitter-client-id
# PKCEのみで運用する場合、TWITTER_CLIENT_SECRETは任意
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_REDIRECT_URI=https://tableno.jp/accounts/twitter_oauth2/login/callback/

# -----------------------------------------------------------------------------
# CORS / 監視
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://tableno.jp,https://www.tableno.jp
# SENTRY_DSN=your-sentry-dsn
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# サイトURL
# -----------------------------------------------------------------------------
SITE_URL=https://tableno.jp

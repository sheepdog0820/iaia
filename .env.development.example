# Local development settings example.
# Copy this file to .env.development and fill only test/development values.
APP_ENV=local
ENVIRONMENT=development
SECRET_KEY=replace-this-with-a-local-development-secret
DEBUG=True
DATABASE_URL=sqlite:///db.sqlite3
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
PUBLIC_SITE_URL=http://127.0.0.1:8000
SITE_DOMAIN=127.0.0.1:8000

# Optional local OAuth settings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://127.0.0.1:8000/accounts/twitter_oauth2/login/callback/

# Local API/frontend settings.
FRONTEND_URL=http://localhost:3000

# Stripe billing - development/test mode only.
# Use Stripe test keys and test Price IDs. Do not put live keys here; use sk_test/pk_test values only.
STRIPE_CHECKOUT_ENABLED=True
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_PREMIUM_YEARLY_PRICE_ID=
STRIPE_PREMIUM_EXPECTED_CURRENCY=jpy
STRIPE_PREMIUM_MONTHLY_EXPECTED_UNIT_AMOUNT=480
STRIPE_PREMIUM_YEARLY_EXPECTED_UNIT_AMOUNT=4800
STRIPE_PUBLISHABLE_KEY=
STRIPE_CUSTOMER_PORTAL_CONFIGURATION_ID=
STRIPE_REVOKE_ON_REFUND_OR_DISPUTE=True

# Premium/legal display values for local verification.
PREMIUM_PRICE_LABEL=月額480円 / 年額4,800円
PREMIUM_MONTHLY_PRICE_LABEL=月額プラン
PREMIUM_MONTHLY_PRICE_DESCRIPTION=480円/月
PREMIUM_YEARLY_PRICE_LABEL=年額プラン
PREMIUM_YEARLY_PRICE_DESCRIPTION=4,800円/年
LEGAL_PAYMENT_METHOD=Stripe Checkoutで利用可能なクレジットカード等の決済手段。
LEGAL_PAYMENT_TIMING=初回申し込み時に課金され、以後は選択した月額または年額サブスクリプションとして自動更新されます。
LEGAL_SERVICE_DELIVERY_TIMING=決済完了後、Stripe Webhookの処理完了をもってプレミアム機能を利用できます。
LEGAL_CANCELLATION_METHOD=ログイン後のプレミアム管理画面からStripe Customer Portalへ移動し、いつでも解約できます。
LEGAL_CANCELLATION_EFFECT=解約後も支払い済み期間の終了まではプレミアム機能を利用できます。
LEGAL_REFUND_POLICY=デジタルサービスの性質上、決済完了後のお客様都合による返金は原則として受け付けません。重複課金や誤請求が確認された場合は個別に対応します。
LEGAL_SELLER_NAME=タブレノ運営
LEGAL_SELLER_ADDRESS=請求があった場合、遅滞なく開示します。
LEGAL_SELLER_PHONE=請求があった場合、遅滞なく開示します。
CONTACT_EMAIL=support@tableno.jp
SUPPORT_EMAIL=support@tableno.jp
DEFAULT_FROM_EMAIL=noreply@tableno.jp
SERVER_EMAIL=noreply@tableno.jp
